{
  "name": "push-all-in-cloud",
  "version": "2.5.0",
  "description": "基于 push-all-in-one 和 hono 开发的云函数推送服务。支持 nodejs/docker/vercel 等部署方式",
  "author": "CaoMeiYouRen",
  "private": true,
  "license": "AGPL-3.0",
  "main": "dist/index.js",
  "scripts": {
    "lint": "cross-env NODE_ENV=production eslint src --fix --ext .ts,.js",
    "release": "semantic-release",
    "build": "rimraf dist && tsup",
    "dev": "cross-env NODE_ENV=development tsx watch --clear-screen=false src/index.ts",
    "watch": "tsc -w",
    "start": "node ./dist/index.js",
    "commit": "cz",
    "prepare": "husky install",
    "test": "jest --config jest.config.ts",
    "test:coverage": "jest --config jest.config.ts --coverage",
    "dev:vercel": "vercel dev",
    "deploy:vercel": "vercel",
    "dev:cloudflare": "wrangler dev"
  },
  "devDependencies": {
    "@cao-mei-you-ren/avue-types": "^1.1.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/debug": "^4.1.13",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "commitizen": "^4.3.1",
    "commitlint": "^20.5.0",
    "commitlint-config-cmyr": "1.0.0",
    "conventional-changelog-cmyr-config": "^3.0.0",
    "cross-env": "^10.1.0",
    "cz-conventional-changelog-cmyr": "2.0.0",
    "debug": "^4.4.3",
    "eslint": "^9.39.2",
    "eslint-config-cmyr": "2.3.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "rimraf": "^6.1.3",
    "semantic-release": "25.0.3",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vercel": "^52.2.1",
    "wrangler": "^4.87.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "axios": "^1.15.0",
    "hono": "^4.12.16",
    "push-all-in-one": "4.5.2",
    "dotenv": "^17.4.2",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "pnpm": {
    "overrides": {
      "@tootallnate/once": "3.0.1",
      "@semantic-release/github>undici": "7.24.4",
      "@vercel/backends>srvx": "0.11.14",
      "@vercel/node>undici": "6.24.1",
      "basic-ftp": "5.2.2",
      "cross-spawn": "^7.0.6",
      "flatted": "^3.4.2",
      "glob@^10": "10.5.0",
      "glob@^11": "11.1.0",
      "handlebars": "^4.7.9",
      "js-yaml@^3": "3.14.2",
      "js-yaml@^4": "4.1.1",
      "lodash": "^4.18.1",
      "lodash-es": "^4.18.1",
      "minimatch": "^3.1.5",
      "picomatch@^2": "2.3.2",
      "picomatch@^4": "4.0.4",
      "rollup": "^4.60.1",
      "tar@^7": "7.5.13",
      "tmp": "0.2.5",
      "yaml": "^2.8.3"
    }
  },
  "keywords": [
    "push",
    "docker",
    "vercel",
    "hono",
    "nodejs",
    "notifications"
  ],
  "engines": {
    "node": ">=18"
  },
  "homepage": "https://github.com/CaoMeiYouRen/push-all-in-cloud#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CaoMeiYouRen/push-all-in-cloud.git"
  },
  "bugs": {
    "url": "https://github.com/CaoMeiYouRen/push-all-in-cloud/issues"
  },
  "type": "module",
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog-cmyr"
    }
  },
  "changelog": {
    "language": "zh"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "npm run lint",
      "git add"
    ]
  }
}
